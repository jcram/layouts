      const screenN = parseInt(item.dataset.screen);
      item.classList.remove('active', 'completed');
      if (screenN === n) item.classList.add('active');
    });

    currentScreen = n;
    document.getElementById('phone-screen').scrollTop = 0;

    document.getElementById('prev-btn').disabled = (n === 1);
    document.getElementById('next-btn').disabled = (n === totalScreens);
    document.getElementById('current-screen-name').textContent = stepInfo[n].name;
    document.getElementById('current-screen-desc').textContent = stepInfo[n].desc;
  }

  function nextScreen() { if (currentScreen < totalScreens) goToScreen(currentScreen + 1); }
  function prevScreen() { if (currentScreen > 1) goToScreen(currentScreen - 1); }

  // Clique nos passos do painel lateral
  document.querySelectorAll('.step-item').forEach(item => {
    item.addEventListener('click', () => goToScreen(parseInt(item.dataset.screen)));
  });

  // Seleção de parcelas (Tela 3) - interação real
  document.querySelectorAll('#parcels-list .parcel-row').forEach(row => {
    row.addEventListener('click', () => {
      document.querySelectorAll('#parcels-list .parcel-row').forEach(r => r.classList.remove('selected'));
      row.classList.add('selected');
      // Atualiza também o resumo da Tela 5
      const parcels = row.dataset.parcels;
      const value = row.dataset.value;
      document.getElementById('approved-parcels').textContent = `${parcels}x de ${value}`;
    });
  });

  // Atalhos de teclado
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight') nextScreen();
    else if (e.key === 'ArrowLeft') prevScreen();
    else if (e.key === 'r' || e.key === 'R') goToScreen(1);
    else if (e.key >= '1' && e.key <= '9') goToScreen(parseInt(e.key));
  });
</script>

</body>
</html>
