<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Protótipo Navegável v5 · Crédito do Trabalhador PaGol</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --color-orange-primary: #F26522;
    --color-orange-hover: #D9551B;
    --color-orange-light: #FFF4EE;
    --color-navy-dark: #0A1F3D;
    --color-navy-medium: #2D3E5C;
    --color-error: #E63946;
    --color-success: #2D8F47;
    --color-success-light: #E8F5EC;
    --color-info: #3B82F6;
    --color-info-bg: #DBE9F8;
    --color-white: #FFFFFF;
    --color-gray-50: #F5F6F8;
    --color-gray-100: #E5E7EB;
    --color-gray-200: #D1D5DB;
    --color-gray-300: #C0C4CC;
    --color-gray-400: #9CA3AF;
    --color-gray-500: #6B7280;
    --color-gray-700: #374151;
    --color-gray-900: #1A1A1A;
    --font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--font-family);
    background: linear-gradient(135deg, #1a2942 0%, #0A1F3D 100%);
    color: var(--color-gray-900);
    min-height: 100vh;
    padding: 24px 16px;
    line-height: 1.4;
  }

  /* ===== LAYOUT GERAL ===== */
  .app-shell {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 32px;
    align-items: start;
  }

  /* ===== PAINEL LATERAL ESQUERDO (PASSOS) ===== */
  .side-panel {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 24px;
    color: white;
    position: sticky;
    top: 24px;
    backdrop-filter: blur(10px);
  }
  .side-panel-title {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-orange-primary);
    margin-bottom: 6px;
  }
  .side-panel-subtitle {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .side-panel-brand {
    color: var(--color-orange-primary);
  }
  .side-panel-desc {
    font-size: 13px;
    color: #B8C2D1;
    margin-bottom: 24px;
    line-height: 1.5;
  }

  .step-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .step-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 12px;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.2s;
    border: 1px solid transparent;
  }
  .step-item:hover {
    background: rgba(255,255,255,0.05);
  }
  .step-item.active {
    background: rgba(242,101,34,0.15);
    border-color: rgba(242,101,34,0.3);
  }
  .step-item.completed .step-circle {
    background: var(--color-success);
    color: white;
    border-color: var(--color-success);
  }
  .step-circle {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.3);
    color: rgba(255,255,255,0.6);
    font-size: 12px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }
  .step-item.active .step-circle {
    background: var(--color-orange-primary);
    color: white;
    border-color: var(--color-orange-primary);
  }
  .step-text {
    flex: 1;
    min-width: 0;
  }
  .step-name {
    font-size: 13px;
    font-weight: 600;
    color: white;
    margin-bottom: 2px;
  }
  .step-item:not(.active):not(.completed) .step-name {
    color: rgba(255,255,255,0.7);
  }
  .step-meta {
    font-size: 11px;
    color: #B8C2D1;
  }

  /* ===== CELULAR (CENTRO) ===== */
  .phone-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .phone {
    width: 380px;
    height: 760px;
    background: var(--color-white);
    border-radius: 36px;
    overflow: hidden;
    box-shadow:
      0 30px 60px rgba(0,0,0,0.4),
      0 0 0 10px #1A1A1A,
      0 0 0 11px #2a2a2a,
      0 0 0 13px #444;
    position: relative;
  }
  .phone::before {
    content: '';
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 110px;
    height: 24px;
    background: #1A1A1A;
    border-radius: 0 0 16px 16px;
    z-index: 50;
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    background: white;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--color-gray-200) transparent;
  }
  .phone-screen::-webkit-scrollbar { width: 4px; }
  .phone-screen::-webkit-scrollbar-thumb { background: var(--color-gray-200); border-radius: 4px; }

  /* Cada tela é absoluta, transição com fade */
  .screen {
    display: none;
    animation: fadeIn 0.35s ease-out;
  }
  .screen.active { display: block; }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Status bar simulada */
  .status-bar {
    height: 38px;
    background: var(--color-navy-dark);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 0 24px 6px;
    color: white;
    font-size: 13px;
    font-weight: 600;
  }
  .status-bar-right {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  /* ===== HEADER PADRÃO PAGOL ===== */
  .pagol-header {
    background: var(--color-navy-dark);
    color: white;
    padding: 14px 20px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .pagol-header-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .pagol-header-back {
    cursor: pointer;
    line-height: 0;
    color: white;
    background: none;
    border: none;
    padding: 0;
  }
  .pagol-header-back:hover { opacity: 0.7; }
  .pagol-header-title {
    font-size: 15px;
    font-weight: 600;
  }
  .pagol-header-title .brand {
    color: var(--color-orange-primary);
    font-weight: 700;
  }
  .pagol-header-help {
    width: 26px;
    height: 26px;
    border: 1.5px solid white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    cursor: pointer;
  }

  .security-banner {
    background: var(--color-gray-50);
    padding: 10px 20px;
    display: flex;
    gap: 10px;
    align-items: center;
    font-size: 12px;
    color: var(--color-gray-700);
    line-height: 1.4;
  }
  .security-banner-icon {
    flex-shrink: 0;
    color: var(--color-gray-700);
  }

  .screen-content {
    padding: 24px 22px 28px;
  }
  .screen-content h2 {
    font-size: 22px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 12px;
    color: var(--color-gray-900);
    letter-spacing: -0.2px;
  }
  .screen-content .subtitle {
    font-size: 14px;
    color: var(--color-gray-500);
    margin-bottom: 24px;
    line-height: 1.6;
  }
  .screen-content .subtitle a {
    color: var(--color-orange-primary);
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
  }

  /* ===== BOTÕES (com interação) ===== */
  .btn-primary {
    width: 100%;
    background: var(--color-orange-primary);
    color: white;
    border: none;
    border-radius: 999px;
    padding: 15px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: transform 0.1s, background 0.15s, box-shadow 0.15s;
    box-shadow: 0 4px 12px rgba(242,101,34,0.25);
  }
  .btn-primary:hover {
    background: var(--color-orange-hover);
    box-shadow: 0 6px 16px rgba(242,101,34,0.35);
  }
  .btn-primary:active { transform: scale(0.98); }

  .btn-secondary {
    width: 100%;
    background: white;
    color: var(--color-orange-primary);
    border: 1.5px solid var(--color-orange-primary);
    border-radius: 999px;
    padding: 13px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    margin-top: 12px;
    transition: background 0.15s;
  }
  .btn-secondary:hover { background: var(--color-orange-light); }

  /* ===== TELA 1: AUTORIZAÇÃO (centralizada) ===== */
  .auth-icon-wrap {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--color-orange-light);
    margin: 8px auto 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .auth-content {
    text-align: center;
  }
  .auth-content h2 {
    text-align: center;
    max-width: 280px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 14px;
  }
  .auth-content .subtitle {
    text-align: center;
    max-width: 300px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 32px;
    font-size: 14px;
    line-height: 1.6;
  }
  .auth-content .subtitle strong {
    color: var(--color-gray-900);
    font-weight: 600;
  }
  .auth-content .legal-text {
    text-align: center;
    font-size: 11px;
    color: var(--color-gray-400);
    margin-top: 20px;
    margin-bottom: 0;
    line-height: 1.5;
    padding: 0 8px;
  }
  .auth-content .legal-text a {
    color: var(--color-gray-500);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: var(--color-gray-200);
    cursor: pointer;
  }
  .auth-content .legal-text a:hover {
    color: var(--color-orange-primary);
    text-decoration-color: var(--color-orange-primary);
  }

  /* ===== TELA 2: TERMO ASSINADO ===== */
  .term-success { text-align: center; padding: 8px 0; }
  .term-success-icon-wrap {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--color-success-light);
    margin: 0 auto 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes pop {
    0% { transform: scale(0); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }
  .term-success-title {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 12px;
    line-height: 1.3;
    letter-spacing: -0.2px;
  }
  .term-success-description {
    font-size: 14px;
    color: var(--color-gray-500);
    line-height: 1.6;
    margin-bottom: 20px;
  }
  .margin-card {
    background: var(--color-gray-50);
    border-radius: 12px;
    padding: 24px 20px;
    margin-bottom: 28px;
    text-align: center;
  }
  .margin-card-highlight {
    background: var(--color-orange-light);
    border: 1px solid #FCD9C4;
    padding: 28px 20px 20px;
  }
  .margin-card-label {
    font-size: 13px;
    color: var(--color-gray-500);
    margin-bottom: 8px;
  }
  .margin-card-value {
    font-size: 32px;
    font-weight: 700;
    color: var(--color-gray-900);
    letter-spacing: -0.5px;
  }
  .margin-card-validity {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 14px;
    color: var(--color-orange-primary);
    font-size: 12px;
    font-weight: 500;
  }

  /* ===== TELA 3: ESCOLHA DE PARCELAS ===== */
  .value-summary {
    background: var(--color-gray-50);
    border-radius: 12px;
    padding: 16px 20px;
    margin-bottom: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .value-summary-label {
    font-size: 13px;
    color: var(--color-gray-500);
    margin-bottom: 4px;
  }
  .value-summary-amount {
    font-size: 22px;
    font-weight: 700;
    color: var(--color-gray-900);
    letter-spacing: -0.3px;
  }
  .value-summary-edit {
    color: var(--color-orange-primary);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
  }

  .parcels-list {
    border-top: 1px solid var(--color-gray-100);
  }
  .parcel-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 4px;
    border-bottom: 1px solid var(--color-gray-100);
    cursor: pointer;
    transition: background 0.15s;
  }
  .parcel-row:hover { background: var(--color-gray-50); }
  .parcel-radio {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 2px solid var(--color-gray-300);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s;
  }
  .parcel-row.selected .parcel-radio {
    border-color: var(--color-orange-primary);
  }
  .parcel-row.selected .parcel-radio::after {
    content: '';
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-orange-primary);
  }
  .parcel-row-text {
    font-size: 14px;
    color: var(--color-gray-500);
  }
  .parcel-row.selected .parcel-row-text {
    color: var(--color-gray-900);
  }
  .parcel-row-text strong { font-weight: 700; }

  .info-disclaimer {
    background: var(--color-info-bg);
    border-radius: 8px;
    padding: 12px 14px;
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 13px;
    color: var(--color-gray-900);
    line-height: 1.5;
    margin: 24px 0;
  }
  .info-disclaimer-icon {
    flex-shrink: 0;
    color: var(--color-info);
  }

  .rate-summary {
    background: var(--color-gray-50);
    border-radius: 10px;
    padding: 14px 16px;
    margin-top: 20px;
    margin-bottom: 8px;
  }
  .rate-summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 0;
    font-size: 13px;
  }
  .rate-summary-row + .rate-summary-row {
    border-top: 1px solid var(--color-gray-100);
  }
  .rate-summary-label { color: var(--color-gray-500); }
  .rate-summary-value { font-weight: 700; color: var(--color-gray-900); }

  /* ===== TELA 4: ANALISANDO ===== */
  .loading-state {
    text-align: center;
    padding: 64px 24px 80px;
  }
  .loading-spinner {
    width: 64px;
    height: 64px;
    margin: 0 auto 32px;
  }
  .loading-spinner svg { animation: spin 1.2s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading-title {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 12px;
    line-height: 1.3;
    color: var(--color-gray-900);
  }
  .loading-description {
    font-size: 14px;
    color: var(--color-gray-500);
    line-height: 1.6;
    max-width: 280px;
    margin: 0 auto;
  }
  .loading-progress {
    margin-top: 32px;
    width: 200px;
    height: 4px;
    background: var(--color-gray-100);
    border-radius: 999px;
    margin-left: auto;
    margin-right: auto;
    overflow: hidden;
  }
  .loading-progress-bar {
    height: 100%;
    background: var(--color-orange-primary);
    border-radius: 999px;
    width: 0;
    animation: progress 3s ease-out forwards;
  }
  @keyframes progress { to { width: 100%; } }

  /* ===== TELA 5: APROVADO ===== */
  .approved-icon-wrap {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--color-success-light);
    margin: 0 auto 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .approved-title {
    font-size: 22px;
    font-weight: 700;
    text-align: center;
    line-height: 1.3;
    margin-bottom: 12px;
    letter-spacing: -0.2px;
  }
  .approved-description {
    font-size: 14px;
    color: var(--color-gray-500);
    text-align: center;
    line-height: 1.6;
    margin-bottom: 28px;
  }
  .approved-summary {
    background: var(--color-gray-50);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 28px;
  }
  .approved-summary-title {
    font-size: 11px;
    color: var(--color-gray-500);
    margin-bottom: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
  }
  .approved-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    font-size: 14px;
  }
  .approved-row + .approved-row {
    border-top: 1px solid var(--color-gray-100);
  }
  .approved-row .label { color: var(--color-gray-700); }
  .approved-row .value { font-weight: 700; color: var(--color-gray-900); }

  /* ===== TELA 6: E-MAIL ===== */
  .email-icon-wrap {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--color-orange-light);
    margin: 0 auto 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .email-title {
    font-size: 22px;
    font-weight: 700;
    text-align: center;
    line-height: 1.3;
    margin-bottom: 12px;
    letter-spacing: -0.2px;
  }
  .email-description {
    font-size: 14px;
    color: var(--color-gray-500);
    text-align: center;
    line-height: 1.6;
    margin-bottom: 24px;
  }
  .email-description strong {
    color: var(--color-gray-900);
    font-weight: 600;
  }

  .info-box {
    background: var(--color-gray-50);
    border-radius: 12px;
    padding: 16px 20px;
    margin-bottom: 20px;
  }

  .email-deadline-alert {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--color-orange-light);
    border: 1px solid #FCD9C4;
    border-radius: 10px;
    padding: 12px 14px;
    color: var(--color-orange-hover);
    font-size: 13px;
    line-height: 1.4;
    margin-bottom: 16px;
  }
  .email-deadline-alert svg {
    flex-shrink: 0;
    color: var(--color-orange-primary);
  }
  .email-deadline-alert strong { font-weight: 700; }

  .info-box-row {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    font-size: 13px;
  }
  .info-box-row + .info-box-row {
    border-top: 1px solid var(--color-gray-100);
  }
  .info-box-row .label { color: var(--color-gray-500); }
  .info-box-row .value { font-weight: 600; color: var(--color-gray-900); }

  .tip-alert {
    background: var(--color-info-bg);
    border-radius: 8px;
    padding: 12px 14px;
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 13px;
    color: var(--color-gray-900);
    line-height: 1.5;
    margin-bottom: 24px;
    text-align: left;
  }
  .tip-alert-icon {
    flex-shrink: 0;
    color: var(--color-info);
  }

  /* ===== TELA: EM ANÁLISE (revisada, sem countdown) ===== */
  .analysis-state {
    text-align: center;
    padding: 48px 24px 40px;
  }
  .analysis-icon-wrap {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: var(--color-info-bg);
    margin: 0 auto 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    animation: pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .analysis-icon-wrap::before {
    content: '';
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 2px solid var(--color-info);
    opacity: 0.3;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.3; }
    50% { transform: scale(1.08); opacity: 0; }
  }
  .analysis-title {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 12px;
    line-height: 1.3;
    color: var(--color-gray-900);
    letter-spacing: -0.2px;
  }
  .analysis-description {
    font-size: 14px;
    color: var(--color-gray-500);
    line-height: 1.6;
    margin-bottom: 28px;
  }
  .analysis-card {
    background: var(--color-gray-50);
    border-radius: 12px;
    padding: 18px 20px;
    margin-bottom: 20px;
    text-align: left;
  }
  .analysis-card-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    font-size: 13px;
